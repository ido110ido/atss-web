rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    function isActiveUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && profile().active == true;
    }

    function sameCompany(data) {
      return isActiveUser() && profile().company == data.company;
    }

    // User profiles are provisioned manually by the admin via the Firebase
    // console — the app only ever reads its own profile.
    match /users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // deliveries/imports are only ever written by the Cloud Functions
    // backend (firebase-admin bypasses these rules entirely) — the web
    // dashboard is read-only for these.
    match /deliveries/{deliveryId} {
      allow read: if sameCompany(resource.data);
      allow write: if false;
    }

    // Workers can also be added/edited directly from the dashboard, in
    // addition to the batch Excel import (Cloud Function, admin SDK). The
    // doc ID is an opaque random ID, unrelated to phone — the app looks
    // workers up by querying the `phone` field, never by predicting the ID,
    // so phone can change freely without orphaning anything. Company may
    // never change, even on update.
    match /workers/{workerId} {
      allow read: if sameCompany(resource.data);
      allow create: if isActiveUser() && request.resource.data.company == profile().company;
      allow update: if sameCompany(resource.data)
        && request.resource.data.company == resource.data.company;
      allow delete: if false;
    }

    match /imports/{importId} {
      allow read: if sameCompany(resource.data);
      allow write: if false;
    }

    match /workerImports/{importId} {
      allow read: if sameCompany(resource.data);
      allow write: if false;
    }
  }
}
